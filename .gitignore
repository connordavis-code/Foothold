# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do NOT commit secrets)
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle migrations metadata cache
/drizzle/meta

# claude code local settings (per-machine, never commit)
.claude/settings.local.json

# superpowers brainstorm session artifacts (HTML mockups, ephemeral state)
.superpowers/

# skills CLI plugin output (npx skills add ...) — installed locally, not source
.agents/
skills-lock.json

# claude-mem session-context dump (regenerated every session, machine-local)
AGENTS.md

# editor settings (per-machine, never commit)
.vscode/
*.code-workspace
