# =============================================================================
# Personal Finance Tool — Environment Variables
# =============================================================================
# Copy this file to .env.local for local dev, or set these in Vercel for prod.
# Never commit .env.local to git — it's in .gitignore.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Get this from Supabase: Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler connection string for serverless / Vercel.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (no pooler) — used by drizzle-kit for migrations.
DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Auth.js (NextAuth)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-32-byte-base64-string-here"

# Email provider for magic-link login (Resend recommended — free tier)
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
AUTH_EMAIL_FROM="finance@yourdomain.com"

# -----------------------------------------------------------------------------
# Plaid
# -----------------------------------------------------------------------------
# Get these from Plaid Dashboard → Team Settings → Keys
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-sandbox-secret"

# Environment: sandbox | development | production
# Start with sandbox for testing with fake data, switch to development for real
# accounts (Plaid gives you 100 free items in development tier).
PLAID_ENV="sandbox"

# Products to enable — comma separated.
# transactions  → bank/credit card transactions
# investments   → brokerage holdings + investment transactions (Fidelity, etc.)
# auth          → account/routing numbers (not needed for v1)
PLAID_PRODUCTS="transactions,investments"

# Country codes — comma separated.
PLAID_COUNTRY_CODES="US"

# A friendly name shown to you in the Plaid Link UI.
PLAID_CLIENT_NAME="Personal Finance Tool"

# -----------------------------------------------------------------------------
# Anthropic API (for Phase 3 coaching layer — optional, can leave blank for now)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Used for callbacks, magic-link emails, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Cron (Phase 5)
# -----------------------------------------------------------------------------
# Vercel Cron passes this as `Authorization: Bearer $CRON_SECRET` on every
# scheduled invocation. Required — without it, anyone hitting /api/cron/*
# could trigger sync / digest jobs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET="generate-a-random-32-byte-base64-string-here"
